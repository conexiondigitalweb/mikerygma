{
  "functions": {
    "api/generate.js": {
      "maxDuration": 300
    },
    "api/preview.js": {
      "maxDuration": 30
    },
    "api/save-generation.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
